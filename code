        }
}

    function tirerUneCarteIA(){

        couleur = nbrHasard(4)                              // défini dans quel tableau on va chercher la carte.
        position = nbrHasard(12)                            // défini quel position on prend la carte.
    
        if (couleur == 0){
            carte = carreau.splice(position,1)
            carte = carte[0]
            mainIA.push(carte)
        }
    
        if (couleur == 1){
