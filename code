        }
    
        if (couleur == 3){
            carte = trefle.splice(position,1)
            carte = carte[0]
            mainIA.push(carte)  
        }
}


    function compteJeu(qui){
        let somme = 0
        for (let i =0; i < qui.length; i++){
            somme += qui[i] 
        }
        return somme
    }


// LE JEU :

