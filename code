    function nbrHasard(max){                            //Cherche un nombre au hasard entre 0 et au max
        return Math.floor(Math.random() * max);
    }


//distribution des cartes :

    function tirerUneCarteJ(){

        couleur = nbrHasard(4)                              // défini dans quel tableau on va chercher la carte.
    
